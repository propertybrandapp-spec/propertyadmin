# Copy this file to .env and fill in your real values.

# Same Supabase project the public site uses — get these from:
# Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Same Cloudflare R2 upload gateway the public site uses. This Worker lives
# in the main site's repo (cloudflare-worker/) and is deployed once from
# there — this project just calls it. Make sure its ALLOWED_ORIGINS secret
# includes this admin console's origin (see the main repo's SETUP.md).
VITE_R2_WORKER_URL=https://propertybrands-r2-upload.your-subdomain.workers.dev

# URL of the public marketing site — used for the "Return to main site"
# links on the login screen and sidebar.
VITE_MAIN_SITE_URL=https://propertybrand.vercel.app/
